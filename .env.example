# SmartPay Agent Environment Variables
# Copy this file to .env and fill in your values

# ─── AI ────────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=
# Model to use. Options: gemini-2.0-flash-lite (30 RPM free), gemini-2.0-flash (15 RPM), gemini-1.5-flash (15 RPM)
GEMINI_MODEL=gemini-2.0-flash-lite

# ─── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# ─── Ports ─────────────────────────────────────────────────────────────────────
BACKEND_PORT=4000
FRONTEND_PORT=3000
ADMIN_PORT=3001
