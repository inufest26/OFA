# SmartPay Agent Environment Variables
# Copy this file to .env and fill in your values

# ─── AI ────────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=
# Model to use. Options: gemini-1.5-flash-latest (higher free quota), gemini-2.0-flash (paid)
GEMINI_MODEL=gemini-1.5-flash-latest

# ─── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# ─── Ports ─────────────────────────────────────────────────────────────────────
BACKEND_PORT=4000
FRONTEND_PORT=3000
ADMIN_PORT=3001
